vector<pair<int,int>> adj[N];   // {neighbor, weight}
vector<int> dis;
int prnt[N];

void bfs(int s) {
    deque<int> dq;
    dq.push_front(s);
    dis[s] = 0;

    while (!dq.empty()) {
        int v = dq.front();
        dq.pop_front();

        for (auto [u, w] : adj[v]) {
            if (dis[u] > dis[v] + w) {
                dis[u] = dis[v] + w;
                prnt[u] = v;

                if (w == 0)
                    dq.push_front(u);
                else
                    dq.push_back(u);
            }
        }
    }
}

void solve() {
    cin >> n >> m;
    int s, e;
    cin >> s >> e;

    dis.assign(n + 1, INF);

    for (int i = 1; i <= n; i++)
        adj[i].clear();

    for (int i = 0; i < m; i++) {
        int a, b, w;
        cin >> a >> b >> w; // weight must be 0 or 1
        adj[a].push_back({b, w});
        adj[b].push_back({a, w}); // remove if graph is directed
    }

    bfs(s);

    if (dis[e] == INF) {
        cout << -1;
        return;
    }

    cout << dis[e] << nl;

    vector<int> ans;
    int curr = e;
    while (curr != s) {
        ans.push_back(curr);
        curr = prnt[curr];
    }
    ans.push_back(s);
    reverse(all(ans));

    for (int x : ans)
        cout << x << " ";
}

